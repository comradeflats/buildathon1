rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return exists(/databases/$(database)/documents/orgMembers/$(request.auth.uid + '_' + orgId));
    }

    function isOrgAdmin(orgId) {
      let member = get(/databases/$(database)/documents/orgMembers/$(request.auth.uid + '_' + orgId));
      return member.data.role in ['owner', 'admin'];
    }

    function isOrgOwner(orgId) {
      let member = get(/databases/$(database)/documents/orgMembers/$(request.auth.uid + '_' + orgId));
      return member.data.role == 'owner';
    }

    // Organizations - readable by all, writable by authenticated users (create), admins (update/delete)
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isOrgAdmin(orgId);
      allow delete: if isAuthenticated() && isOrgOwner(orgId);
    }

    // Organization Members - readable by org members, writable by org admins
    match /orgMembers/{memberId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isOrgMember(resource.data.organizationId)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isOrgAdmin(request.resource.data.organizationId)
      );
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
      allow delete: if isAuthenticated() && (
        isOrgAdmin(resource.data.organizationId) ||
        request.auth.uid == resource.data.userId
      );
    }

    // Users - users can read and update their own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Events - public read, org admins can write
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       isOrgAdmin(request.resource.data.organizationId) &&
                       request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
      allow delete: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
    }

    // Teams - public read, authenticated users can create, owners/org admins can update/delete
    match /teams/{teamId} {
      allow read: if true;
      allow create: if true; // Allow anonymous team submissions
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId ||
        isOrgAdmin(resource.data.organizationId)
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId ||
        isOrgAdmin(resource.data.organizationId)
      );
    }

    // Themes - public read, org admins can write
    match /themes/{themeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
      allow delete: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
    }

    // Votes - judges can read their own votes, create/update votes
    // Org admins can read all votes for their events
    match /votes/{voteId} {
      allow read: if true; // Public read for leaderboards
      allow create: if true; // Allow anonymous voting
      allow update: if resource.data.judgeId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.judgeId == request.auth.uid ||
        isOrgAdmin(resource.data.organizationId)
      );
    }
  }
}
