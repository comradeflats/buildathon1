rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get member document
    function getOrgMemberDoc(orgId) {
      return get(/databases/$(database)/documents/orgMembers/$(request.auth.uid + '_' + orgId));
    }

    // Check if user is a member of the organization
    function isOrgMember(orgId) {
      return exists(/databases/$(database)/documents/orgMembers/$(request.auth.uid + '_' + orgId));
    }

    // Check if user is an admin or owner
    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && getOrgMemberDoc(orgId).data.role in ['owner', 'admin'];
    }

    // Check if user is the owner
    function isOrgOwner(orgId) {
      return isOrgMember(orgId) && getOrgMemberDoc(orgId).data.role == 'owner';
    }

    // Check if user has judging privileges (judge, admin, or owner)
    function isOrgJudge(orgId) {
      return isOrgMember(orgId) && getOrgMemberDoc(orgId).data.role in ['owner', 'admin', 'judge'];
    }

    // Helper to get event data
    function getEventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    // --- Rules ---

    // Organizations - readable by all, writable by authenticated users (create), admins (update/delete)
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isOrgAdmin(orgId);
      allow delete: if isAuthenticated() && isOrgOwner(orgId);
    }

    // Organization Members - readable by org members, writable by org admins
    match /orgMembers/{memberId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isOrgMember(resource.data.organizationId)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isOrgAdmin(request.resource.data.organizationId)
      );
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
      allow delete: if isAuthenticated() && (
        isOrgAdmin(resource.data.organizationId) ||
        request.auth.uid == resource.data.userId
      );
    }

    // Users - PRIVACY FIX: users can only read and update their OWN profile
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Events - public read, org admins can write
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       isOrgAdmin(request.resource.data.organizationId) &&
                       request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow delete: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
    }

    // Teams - AUTH REQUIRED + SUBMISSION CODE VERIFICATION
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                       // Verify the code matches the event's secret code
                       request.resource.data.submissionCode == getEventData(request.resource.data.eventId).submissionCode;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId ||
        isOrgAdmin(resource.data.organizationId)
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId ||
        isOrgAdmin(resource.data.organizationId)
      );
    }

    // Themes - public read, org admins can write
    match /themes/{themeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow delete: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
    }

    // Votes - AUTH REQUIRED + TOGGLE LOGIC (Peer vs Expert)
    match /votes/{voteId} {
      allow read: if true; // Public read for leaderboards
      allow create: if isAuthenticated() && (
        // Option A: Peer Voting (Anyone signed in can vote)
        getEventData(request.resource.data.eventId).votingModel == 'peer' ||
        // Option B: Expert Judging (Only designated org judges can vote)
        isOrgJudge(request.resource.data.organizationId)
      );
      allow update: if isAuthenticated() && (
        resource.data.judgeId == request.auth.uid ||
        isOrgAdmin(resource.data.organizationId)
      );
      allow delete: if isAuthenticated() && (
        resource.data.judgeId == request.auth.uid ||
        isOrgAdmin(resource.data.organizationId)
      );
    }
  }
}
